{
  "format_version": "1.21.130",
  "minecraft:ui-root": {
    "description": {
      "identifier": "minecraft:barrel_screen"
    },
    "attribs": {
      "root_point": "minecraft:screen"
    },
    "layout": {
      "markup": [
        {
          "tag": "Container.Layout",
          "children": [
            {
              "tag": "Context",
              "attribs": { "data": { "$path": "$.minecraft.container" } },
              "children": [
                {
                  "tag": "Panel",
                  "attribs": { "colorMode": "barrel" },
                  "children": [
                    {
                      "tag": "Panel.Text",
                      "attribs": { "text": { "$relativePath": "$.name" } }
                    },
                    {
                      "tag": "Panel.CloseButton",
                      "attribs": {
                        "onClick": {
                          "$relativePath": "$.closeCommand"
                        }
                      }
                    },
                    { "tag": "Panel.Spacing" },
                    {
                      "tag": "Container.FixedGridLayout",
                      "children": [
                        {
                          "tag": "Context.List",
                          "attribs": {
                            "data": {
                              "$relativePath": "$.items.barrelContainer"
                            }
                          },
                          "children": [
                            {
                              "tag": "Container.Item",
                              "attribs": { "item": { "$relativePath": "$" } }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
