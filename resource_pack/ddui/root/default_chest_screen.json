{
  "format_version": "1.21.130",
  "minecraft:ui-root": {
    "description": {
      "identifier": "minecraft:default_chest_screen"
    },
    "attribs": {
      "root_point": "minecraft:screen"
    },
    "layout": {
      "markup": [
        {
          "component": "Container.Layout",
          "children": [
            {
              "component": "Context",
              "attribs": {
                "data": {
                  "$path": "$.minecraft.container"
                }
              },
              "children": [
                {
                  "component": "Panel",
                  "attribs": {
                    "colorMode": "dark"
                  },
                  "children": [
                    {
                      "component": "Panel.Text",
                      "attribs": {
                        "text": {
                          "$relativePath": "$.name"
                        }
                      }
                    },
                    {
                      "component": "Panel.CloseButton",
                      "attribs": {
                        "onClick": {
                          "$relativePath": "$.closeCommand"
                        }
                      }
                    },
                    {
                      "component": "Panel.Spacing"
                    },
                    {
                      "component": "ScrollableGridLayout",
                      "attribs": {
                        "data": {
                          "$relativePath": "$.slots.levelEntityContainer"
                        }
                      },
                      "children": [
                        {
                          "component": "Container.Slot",
                          "attribs": {
                            "item": {
                              "$relativePath": "$"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}