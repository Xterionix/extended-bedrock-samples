{
  "namespace": "beta_feedback_qr",

  // -----------------------------------------------
  //
  //    screen
  //
  // -----------------------------------------------
  "beta_feedback_qr@common.base_screen": {
    "button_mappings": [
      {
        "from_button_id": "button.menu_cancel",
        "to_button_id": "button.menu_exit",
        "mapping_type": "global"
      }
    ],
    "force_render_below": true,
    "$screen_content": "beta_feedback_qr.beta_feedback_qr_screen_content",
    "$screen_background_control": "beta_feedback_qr.background"
  },

  "background@common.screen_background": {
    "alpha": 0.65,
    "layer": 1
  },

  "beta_feedback_qr_screen_content": {
    "type": "panel",
    "controls": [
      {
        "dialog@beta_feedback_qr.beta_feedback_qr_popup": {
          "layer": 1
        }
      }
    ]
  },

  // -----------------------------------------------
  //
  //    dialog
  //
  // -----------------------------------------------
  "beta_feedback_qr_popup@common_dialogs.main_panel_one_button": {
    "size": [ 380, 210 ],
    "$text_name": "betaFeedback.qr.title",
    "$child_control": "beta_feedback_qr.main_panel_qr",
    "$button_panel": "beta_feedback_qr.close_button"
  },

  "close_button@common_buttons.light_text_button": {
    "size": [ "100% - 14px", 30 ],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "$pressed_button_name": "button.menu_exit",
    "$button_text": "betaFeedback.qr.close",
    "$button_text_binding_type": "none"
  },

  "main_panel_qr": {
    "type": "stack_panel",
    "size": [ "100% - 4px", "100% - 4px" ],
    "orientation": "horizontal",
    "controls": [
      {
        "left_panel@beta_feedback_qr.left_panel": {}
      },
      {
        "divider@common.vertical_divider": {
          "size": [ 8, "100%" ],
          "anchor_from": "top_middle",
          "anchor_to": "top_middle"
        }
      },
      {
        "right_panel@beta_feedback_qr.right_panel": {}
      }
    ]
  },

  // -----------------------------------------------
  //
  //    panels
  //
  // -----------------------------------------------
  "left_panel": {
    "type": "stack_panel",
    "size": [ "50% - 6px", "100%" ],
    "orientation": "vertical",
    "controls": [
      {
        "header@common.minecraftTenLabel": {
          "size": [ "100%", 12 ],
          "text": "betaFeedback.qr.header",
          "layer": 2,
          "text_alignment": "left"
        }
      },
      {
        "header_padding": {
          "type": "panel",
          "size": [ "100%", 6 ]
        }
      },
      {
        "body_text_line1": {
          "type": "label",
          "size": [ "100%", "default" ],
          "text": "betaFeedback.qr.body.line1",
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "layer": 2,
          "text_alignment": "left",
          "color": "$body_text_color",
          "font_type": "smooth"
        }
      },
      {
        "body_line_padding": {
          "type": "panel",
          "size": [ "100%", 6 ]
        }
      },
      {
        "body_text_line2": {
          "type": "label",
          "size": [ "100%", "default" ],
          "text": "betaFeedback.qr.body.line2",
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "layer": 2,
          "text_alignment": "left",
          "color": "$body_text_color",
          "font_type": "smooth"
        }
      }
    ]
  },

  "right_panel": {
    "type": "stack_panel",
    "size": [ "50% - 6px", "100%" ],
    "orientation": "vertical",
    "controls": [
      {
        "qr_panel": {
          "type": "panel",
          "size": [ "100%", "fill" ],
          "controls": [
            {
              "qr_border": {
                "type": "image",
                "texture": "textures/ui/White",
                "keep_ratio": false,
                "anchor_to": "center",
                "anchor_from": "center",
                "size": [ "100%y", "90%" ],
                "layer": 1
              }
            },
            {
              "qr_code": {
                "type": "custom",
                "renderer": "qr_code_renderer",
                "size": [ "100%y", "90% - 8px" ],
                "anchor_to": "center",
                "anchor_from": "center",
                "layer": 2,
                "bindings": [
                  {
                    "binding_name": "#qr_code_content"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}
